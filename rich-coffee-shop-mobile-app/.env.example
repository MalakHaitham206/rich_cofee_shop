# ----- Backend API -----
# URL of the Fastify backend server
# Development (local):  http://localhost:3000
# Development (device): http://<your-local-ip>:3000  (e.g. http://192.168.1.10:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
